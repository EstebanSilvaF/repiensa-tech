generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  active
  inactive
  expired

  @@map("subscription_status")
}

enum ProductCondition {
  new
  good
  regular

  @@map("product_condition")
}

enum ProductStatus {
  available
  reserved
  sold

  @@map("product_status")
}

enum ProductCategory {
  microcontrollers
  sensors
  memory
  displays
  cables
  power
  books_notes
  lab_science
  art_design
  tools_hardware
  sports_fitness
  clothing_accessories
  furniture_decor
  musical_instruments
  stationery_office
  home_kitchen
  services
  other

  @@map("product_category")
}

enum ReservationStatus {
  active
  completed
  expired

  @@map("reservation_status")
}

enum ChatStatus {
  open
  delivery_confirmed

  @@map("chat_status")
}

enum MessageType {
  text
  appointment

  @@map("message_type")
}

enum AppointmentStatus {
  pending
  accepted
  rejected

  @@map("appointment_status")
}

enum NotificationType {
  reservation_confirmed
  reservation_expiring
  reservation_expired
  product_approved
  new_message
  new_interested
  sale_completed
  purchase_completed
  admin_published

  @@map("notification_type")
}

enum NotificationRef {
  product
  chat
  reservation
  transaction

  @@map("notification_ref")
}

model University {
  id                 String             @id @default(cuid())
  name               String             @db.VarChar(200)
  emailDomain        String             @unique @map("email_domain") @db.VarChar(100)
  subscriptionStatus SubscriptionStatus @default(inactive) @map("subscription_status")
  subscriptionStart  DateTime?          @map("subscription_start") @db.Date
  subscriptionEnd    DateTime?          @map("subscription_end") @db.Date
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  products Product[]

  @@map("universities")
}

model Product {
  id            String           @id @default(cuid())
  sellerId      String           @map("seller_id")
  universityId  String           @map("university_id")
  name          String           @db.VarChar(200)
  description   String?
  price         Decimal          @default(0) @db.Decimal(10, 2)
  isDonation    Boolean          @default(false) @map("is_donation")
  category      ProductCategory
  condition     ProductCondition
  status        ProductStatus    @default(available)
  imageUrl      String           @map("image_url")
  imagePublicId String?          @map("image_public_id")
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  university   University    @relation(fields: [universityId], references: [id], onDelete: Restrict)
  reservations Reservation[]
  chats        Chat[]
  transactions Transaction[]

  @@index([sellerId], map: "idx_products_seller")
  @@index([universityId], map: "idx_products_university")
  @@index([status], map: "idx_products_status")
  @@index([category], map: "idx_products_category")
  @@map("products")
}

model Reservation {
  id        String            @id @default(cuid())
  productId String            @map("product_id")
  buyerId   String            @map("buyer_id")
  feePaid   Decimal           @map("fee_paid") @db.Decimal(10, 2)
  status    ReservationStatus @default(active)
  expiresAt DateTime          @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  transactions Transaction[]

  @@unique([productId, status], map: "uq_product_active_reservation")
  @@index([productId], map: "idx_reservations_product")
  @@index([buyerId], map: "idx_reservations_buyer")
  @@index([status], map: "idx_reservations_status")
  @@index([expiresAt], map: "idx_reservations_expires")
  @@map("reservations")
}

model Chat {
  id        String     @id @default(cuid())
  productId String     @map("product_id")
  buyerId   String     @map("buyer_id")
  sellerId  String     @map("seller_id")
  status    ChatStatus @default(open)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  product      Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  messages     Message[]
  transactions Transaction[]

  @@unique([productId, buyerId], map: "uq_chat_per_product_buyer")
  @@index([productId], map: "idx_chats_product")
  @@index([buyerId], map: "idx_chats_buyer")
  @@index([sellerId], map: "idx_chats_seller")
  @@map("chats")
}

model Message {
  id                  String             @id @default(cuid())
  chatId              String             @map("chat_id")
  senderId            String             @map("sender_id")
  type                MessageType        @default(text)
  content             String
  appointmentStatus   AppointmentStatus? @map("appointment_status")
  appointmentDay      String?            @map("appointment_day") @db.VarChar(100)
  appointmentTime     String?            @map("appointment_time") @db.VarChar(50)
  appointmentLocation String?            @map("appointment_location") @db.VarChar(200)
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId], map: "idx_messages_chat")
  @@index([senderId], map: "idx_messages_sender")
  @@map("messages")
}

model Transaction {
  id            String    @id @default(cuid())
  productId     String    @unique @map("product_id")
  sellerId      String    @map("seller_id")
  buyerId       String    @map("buyer_id")
  chatId        String    @map("chat_id")
  reservationId String?   @map("reservation_id")
  finalPrice    Decimal   @map("final_price") @db.Decimal(10, 2)
  confirmedAt   DateTime  @default(now()) @map("confirmed_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  chat        Chat         @relation(fields: [chatId], references: [id], onDelete: Restrict)
  reservation Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([sellerId], map: "idx_transactions_seller")
  @@index([buyerId], map: "idx_transactions_buyer")
  @@index([reservationId], map: "idx_transactions_reservation")
  @@map("transactions")
}

model Notification {
  id            String            @id @default(cuid())
  userId        String            @map("user_id")
  type          NotificationType
  title         String            @db.VarChar(200)
  description   String?
  isRead        Boolean           @default(false) @map("is_read")
  referenceId   String?           @map("reference_id")
  referenceType NotificationRef?  @map("reference_type")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([userId], map: "idx_notifications_user")
  @@index([userId, isRead], map: "idx_notifications_is_read")
  @@map("notifications")
}
