{
  "type": "object",
  "required": ["token", "user"],
  "properties": {
    "token": { "type": "string" },
    "user": {
      "type": "object",
      "required": ["id", "email", "role"],
      "properties": {
        "id": { "type": "string" },
        "university_id": { "type": "string" },
        "full_name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "admin"] }
      }
    }
  }
}
